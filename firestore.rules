rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Projects collection - public read, admin write
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null && 
        (request.auth.token.email == 'alifelski@gmail.com' || 
         request.auth.token.email == 'rgermick@gmail.com');
    }
    
    // Site config (about content) - public read, admin write
    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if request.auth != null && 
        (request.auth.token.email == 'alifelski@gmail.com' || 
         request.auth.token.email == 'rgermick@gmail.com');
    }
    
    // Contact submissions - anyone can create, only admins can read/update/delete
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && 
        (request.auth.token.email == 'alifelski@gmail.com' || 
         request.auth.token.email == 'rgermick@gmail.com');
    }
  }
}

